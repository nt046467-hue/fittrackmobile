{
  "buildCommand": "pip install --break-system-packages -r requirements.txt",
  "outputDirectory": ".",
  "functions": {
    "api/index.py": {
      "runtime": "python@3.11",
      "maxDuration": 30
    }
  },
  "routes": [{ "src": "/(.*)", "dest": "/api/index.py" }],
  "env": {
    "ENVIRONMENT": "production"
  }
}
